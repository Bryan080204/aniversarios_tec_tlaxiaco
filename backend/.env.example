# =====================================================
# Configuración del Backend - TEC Tlaxiaco
# =====================================================
# Copia este archivo como .env y configura los valores

# Puerto del servidor (por defecto: 3001)
PORT=3001

# =====================================================
# Configuración de PostgreSQL
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=basetec

# =====================================================
# Notas:
# - Asegúrate de tener PostgreSQL instalado y corriendo
# - Crea la base de datos antes de ejecutar el servidor:
#   CREATE DATABASE basetec;
# - Ejecuta schema.sql para crear las tablas:
#   psql -U postgres -d basetec -f schema.sql
# =====================================================
